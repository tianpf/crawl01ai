# Doubao Brand Information API Configuration
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_BASE_URL=https://api.doubao.example.com/v1

# Server Configuration  
SERVER_HOST=localhost
SERVER_PORT=8080
DEBUG=false

# Scoring Configuration
DEFAULT_SCORING_CRITERIA=market_position,brand_awareness,innovation,financial_performance,sustainability
MAX_SEARCH_RESULTS=20

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
REQUEST_TIMEOUT=30